{
	"name": "user-management",
	"version": "1.0.0",
	"description": "A user management system with Node.js, Express, SQLite, and Knex.",
	"main": "dist/server.js",
	"scripts": {
		"dev": "nodemon src/server.ts",
		"build": "tsc",
		"prestart": "pnpm run prepare",
		"start": "node dist/src/server.js",
		"lint": "eslint src --ext .ts",
		"format": "prettier --write \"src/**/*.ts\"",
		"test": "cross-env NODE_ENV=test jest --runInBand --coverage",
		"test:watch": "NODE_ENV=test jest --watch",
		"test:integration": "cross-env NODE_ENV=test jest tests/integration",
		"test:unit": "jest tests/unit",
		"migrate": "knex migrate:latest",
		"rollback": "knex migrate:rollback",
		"seed": "knex seed:run",
		"prepare": "pnpm run build && pnpm run migrate"
	},
	"dependencies": {
		"cors": "^2.8.5",
		"dotenv": "^16.4.7",
		"express": "^4.21.2",
		"knex": "^3.1.0",
		"sqlite3": "^5.1.7",
		"swagger-ui-express": "^5.0.1",
		"yamljs": "^0.3.0",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@types/cors": "^2.8.17",
		"@types/express": "^5.0.0",
		"@types/jest": "^29.5.14",
		"@types/node": "^22.13.9",
		"@types/supertest": "^6.0.2",
		"@types/swagger-ui-express": "^4.1.8",
		"@types/yamljs": "^0.2.34",
		"@typescript-eslint/eslint-plugin": "^8.26.0",
		"@typescript-eslint/parser": "^8.26.0",
		"cross-env": "^7.0.3",
		"eslint": "^9.21.0",
		"jest": "^29.7.0",
		"nodemon": "^3.1.9",
		"prettier": "^3.5.3",
		"supertest": "^7.0.0",
		"ts-jest": "^29.2.6",
		"ts-node": "^10.9.2",
		"typescript": "^5.8.2"
	}
}
